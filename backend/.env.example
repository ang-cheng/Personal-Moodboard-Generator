# ============================================================================
# Personal Moodboard Generator - Environment Configuration
# ============================================================================
#
# This file shows all available environment variables for the application.
# 
# TO USE:
# 1. Copy this file to .env (in the same directory)
# 2. Replace the placeholder values with your actual values
# 3. The app will automatically load these when it starts
#
# DO NOT commit the .env file to version control (it's in .gitignore)
# This .env.example file IS safe to commit as documentation.
#
# ============================================================================
# FLASK ENVIRONMENT
# ============================================================================
# Options: development, production, testing
# Use 'development' for local work (shows detailed error messages)
# Use 'production' for deployment (hides error details for security)
FLASK_ENV=development

# ============================================================================
# SERVER SETTINGS
# ============================================================================
# Port on which the Flask server will listen
# Default: 5000
# Examples: 5000, 8000, 3000
PORT=5000

# ============================================================================
# UNSPLASH API CONFIGURATION
# ============================================================================
# Your Unsplash API access key for searching images
# 
# HOW TO GET YOUR KEY:
# 1. Go to https://unsplash.com/oauth/applications
# 2. Click "Create a new application"
# 3. Accept their terms and click "Create application"
# 4. Copy your "Access Key" from the Application Details page
# 5. Paste it below
#
# WARNING: Keep this key SECRET! Do not share or commit to version control.
# Without this key, the app cannot fetch images from Unsplash.
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ============================================================================
# MOODBOARD GENERATION SETTINGS
# ============================================================================
# Default number of images to fetch when generating a moodboard
# Default: 5
# Range: 1-30 (Unsplash API limit)
# Note: Higher values take longer to process
DEFAULT_NUM_IMAGES=5

# Default number of dominant colors to extract from images
# Default: 5
# Range: 1-10
# Note: This controls the size of the color palette generated
DEFAULT_NUM_CLUSTERS=5

# ============================================================================
# LOGGING SETTINGS (Optional, for future use)
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO
